<?xml version="1.0" encoding="utf-8" ?>
<!--
  Coverage exclusions for infrastructure adapters that Sonar incorrectly treats as
  fully "new code" after path moves in the Engine clean-architecture refactor.
  These adapters need integration/manual testing (FTP, Quartz, USB WMI, VSS IPC, UNC).
-->
<SonarQubeAnalysisProperties
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns="http://www.sonarsource.com/msbuild/integration/2015/1">
  <Property Name="sonar.coverage.exclusions">**/Providers/Storage/FTPStorage.cs,**/Providers/Scheduler/**,**/Providers/Media/**,**/Providers/Vss/**,**/Utils/Security/Network.cs</Property>
</SonarQubeAnalysisProperties>
