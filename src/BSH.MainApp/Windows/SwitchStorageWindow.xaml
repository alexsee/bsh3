<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="BSH.MainApp.Windows.SwitchStorageWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:BSH.MainApp.Helpers"
    xmlns:viewmodels="using:BSH.MainApp.ViewModels.Windows"
    xmlns:winex="using:WinUIEx"
    Title="{helpers:ResourceString Name=SwitchStorage_Title}"
    Width="640"
    Height="620"
    IsAlwaysOnTop="True"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="True"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" d:DataContext="{d:DesignInstance Type=viewmodels:SwitchStorageViewModel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="28,24,28,20" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="560" HorizontalAlignment="Stretch" Spacing="20">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="{helpers:ResourceString Name=SwitchStorage_Title}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{helpers:ResourceString Name=SwitchStorage_Description}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <ComboBox
                    Header="{helpers:ResourceString Name=SwitchStorage_MediumType}"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{x:Bind ViewModel.MediumTypeOptions}"
                    SelectedIndex="{x:Bind ViewModel.SelectedMediumIndex, Mode=TwoWay}" />

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.LocalTargetVisibility, Mode=OneWay}">
                    <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=SwitchStorage_SelectDrive}" />
                    <ListView
                        Height="220"
                        ItemsSource="{x:Bind ViewModel.AvailableDrives, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName" />
                    <Button Command="{x:Bind ViewModel.RefreshDrivesCommand}" Content="{helpers:ResourceString Name=SwitchStorage_RefreshDrives}" HorizontalAlignment="Left" />
                </StackPanel>

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.FtpTargetVisibility, Mode=OneWay}">
                    <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=SwitchStorage_FtpServer}" />
                    <TextBox Header="{helpers:ResourceString Name=SwitchStorage_FtpHost}" Text="{x:Bind ViewModel.FtpHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="{helpers:ResourceString Name=SwitchStorage_FtpPort}" Text="{x:Bind ViewModel.FtpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="{helpers:ResourceString Name=SwitchStorage_FtpUsername}" Text="{x:Bind ViewModel.FtpUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <PasswordBox Header="{helpers:ResourceString Name=SwitchStorage_FtpPassword}" Password="{Binding FtpPassword, Mode=TwoWay}" />
                    <TextBox Header="{helpers:ResourceString Name=SwitchStorage_FtpPath}" Text="{x:Bind ViewModel.FtpFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Header="{helpers:ResourceString Name=SwitchStorage_FtpEncoding}"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.FtpEncodings}"
                        SelectedItem="{x:Bind ViewModel.FtpEncoding, Mode=TwoWay}" />
                    <CheckBox Content="{helpers:ResourceString Name=SwitchStorage_EnforceUnencrypted}" IsChecked="{x:Bind ViewModel.FtpEnforceUnencrypted, Mode=TwoWay}" />
                    <Button Command="{x:Bind ViewModel.TestFtpConnectionCommand}" Content="{helpers:ResourceString Name=SwitchStorage_TestConnection}" HorizontalAlignment="Left" />
                </StackPanel>

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.ValidationErrorMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </ScrollViewer>

        <Grid
            Grid.Row="1"
            Padding="28,12"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Command="{x:Bind ViewModel.CancelCommand}" Content="{helpers:ResourceString Name=SwitchStorage_Cancel}" />
                <Button Command="{x:Bind ViewModel.ConfirmCommand}" Content="{helpers:ResourceString Name=SwitchStorage_Confirm}" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</winex:WindowEx>
