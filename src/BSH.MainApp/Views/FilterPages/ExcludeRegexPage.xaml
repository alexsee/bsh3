<Page
    x:Class="BSH.MainApp.Views.FilterPages.ExcludeRegexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:BSH.MainApp.Helpers">

	<Grid RowSpacing="12" Padding="8">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ListView Grid.Row="0"
                    ItemsSource="{Binding RegexPatterns}"
                    SelectedItem="{Binding SelectedRegexPattern, Mode=TwoWay}">
			<ListView.Header>
				<TextBlock FontWeight="Bold" Text="{helpers:ResourceString Name=Filter_Column_Pattern}" />
			</ListView.Header>
		</ListView>
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<TextBox x:Name="RegexInput"
                        PlaceholderText="{helpers:ResourceString Name=Filter_EnterRegex}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        Height="80"
                        Margin="0,0,10,0"
                        Text="{Binding RegexInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

			<StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10" VerticalAlignment="Top">
				<Button Content="{helpers:ResourceString Name=MsgBox_Add}" Command="{Binding AddRegexCommand}" CommandParameter="{Binding RegexInputText}" />
				<Button Content="{helpers:ResourceString Name=MsgBox_Remove}" Command="{Binding RemoveRegexCommand}" />
			</StackPanel>
		</Grid>
	</Grid>
</Page>
