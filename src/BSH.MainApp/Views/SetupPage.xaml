<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BSH.MainApp.Views.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:BSH.MainApp.Converters"
    xmlns:controls="using:BSH.MainApp.Controls"
    xmlns:models="using:BSH.MainApp.Models"
    xmlns:viewmodels="using:BSH.MainApp.ViewModels"
    xmlns:engine="using:Brightbits.BSH.Engine"
    xmlns:helpers="using:BSH.MainApp.Helpers"
    d:DataContext="{d:DesignInstance Type=viewmodels:SetupViewModel}"
    Background="White"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:EnumComparisonConverter x:Key="EnumComparisonConverter" />
        <engine:TaskType x:Key="TaskType_Auto">Auto</engine:TaskType>
        <engine:TaskType x:Key="TaskType_Manual">Manual</engine:TaskType>
        <engine:MediaTargetKind x:Key="Target_Local">LocalDrive</engine:MediaTargetKind>
        <engine:MediaTargetKind x:Key="Target_Unc">Unc</engine:MediaTargetKind>
        <engine:MediaTargetKind x:Key="Target_Ftp">Ftp</engine:MediaTargetKind>
        <models:SetupImportSourceKind x:Key="Import_Local">LocalMedia</models:SetupImportSourceKind>
        <models:SetupImportSourceKind x:Key="Import_Ftp">Ftp</models:SetupImportSourceKind>
        <models:SetupImportSourceKind x:Key="Import_Path">ExplicitPath</models:SetupImportSourceKind>
    </Page.Resources>

    <Grid Background="White">
        <Grid
            Width="800"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Margin="40,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Spacing="10"
                Visibility="{x:Bind ViewModel.WizardChromeVisibility, Mode=OneWay}">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Opacity="0.75"
                    TextWrapping="WrapWholeWords"
                    Text="{x:Bind ViewModel.Description, Mode=OneWay}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,28,0,0" VerticalScrollBarVisibility="Auto">
                <Grid Background="White">
                    <!-- Welcome -->
                    <StackPanel
                        Visibility="{x:Bind ViewModel.WelcomeVisibility, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Spacing="0">
                        <TextBlock
                            FontSize="32"
                            FontWeight="SemiBold"
                            TextAlignment="Center"
                            Text="{helpers:ResourceString Name=Setup_Hero_Title}" />
                        <TextBlock
                            Margin="0,14,0,32"
                            FontSize="15"
                            Opacity="0.72"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Text="{helpers:ResourceString Name=Setup_Hero_Subtitle}" />

                        <Border
                            Padding="20,18"
                            Background="#F3F8FF"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="2"
                            CornerRadius="8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="22"
                                    Glyph="&#xE8B7;"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_NewSetup_Title}" />
                                    <TextBlock
                                        Opacity="0.75"
                                        TextWrapping="WrapWholeWords"
                                        Text="{helpers:ResourceString Name=Setup_NewSetup_Description}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="2"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.StartNewSetupCommand}"
                                    Content="{helpers:ResourceString Name=Setup_NewSetup_Continue}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,20,0,0"
                            Padding="20,18"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="22"
                                    Glyph="&#xE8B5;"
                                    VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Import_Title}" />
                                    <TextBlock
                                        Opacity="0.75"
                                        TextWrapping="WrapWholeWords"
                                        Text="{helpers:ResourceString Name=Setup_Import_Description}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="2"
                                    MinWidth="120"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind ViewModel.StartImportCommand}"
                                    Content="{helpers:ResourceString Name=Setup_Import_Button}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Sources -->
                    <Grid Visibility="{x:Bind ViewModel.SourcesVisibility, Mode=OneWay}" RowSpacing="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="180" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button
                            Grid.Row="0"
                            MinHeight="44"
                            Padding="16,10"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AddSourceFolderCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="16" />
                                <TextBlock Text="{helpers:ResourceString Name=Setup_Sources_AddFolder}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}" />

                        <Button
                            Grid.Row="2"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.RemoveSourceFolderCommand}"
                            Content="{helpers:ResourceString Name=Setup_Sources_RemoveSelected}" />
                    </Grid>

                    <!-- Target -->
                    <StackPanel Spacing="28" Visibility="{x:Bind ViewModel.TargetVisibility, Mode=OneWay}">
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Target_Local_Title}"
                                Description="{helpers:ResourceString Name=Setup_Target_Local_Description}"
                                Glyph="&#xEDA2;"
                                IsSelected="{Binding SelectedTargetKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Target_Local}}"
                                Command="{x:Bind ViewModel.SelectTargetCommand}"
                                CommandParameter="{converters:EnumValue Type=engine:MediaTargetKind, Member=LocalDrive}" />
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Target_Unc_Title}"
                                Description="{helpers:ResourceString Name=Setup_Target_Unc_Description}"
                                Glyph="&#xE968;"
                                IsSelected="{Binding SelectedTargetKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Target_Unc}}"
                                Command="{x:Bind ViewModel.SelectTargetCommand}"
                                CommandParameter="{converters:EnumValue Type=engine:MediaTargetKind, Member=Unc}" />
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Target_Ftp_Title}"
                                Description="{helpers:ResourceString Name=Setup_Target_Ftp_Description}"
                                Glyph="&#xE839;"
                                IsSelected="{Binding SelectedTargetKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Target_Ftp}}"
                                Command="{x:Bind ViewModel.SelectTargetCommand}"
                                CommandParameter="{converters:EnumValue Type=engine:MediaTargetKind, Member=Ftp}" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.LocalTargetVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Target_SelectDrive}" />
                            <TextBlock Opacity="0.72" TextWrapping="WrapWholeWords"
                                       Text="{helpers:ResourceString Name=Setup_Target_DriveHint}" />
                            <ListView
                                Height="160"
                                ItemsSource="{x:Bind ViewModel.AvailableDrives, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                                DisplayMemberPath="DisplayName" />
                            <Button Command="{x:Bind ViewModel.RefreshDrivesCommand}" Content="{helpers:ResourceString Name=Setup_Target_RefreshDrives}" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.UncTargetVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Target_EnterNetworkShare}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_NetworkPath}" Text="{x:Bind ViewModel.UncPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_UsernameOptional}" Text="{x:Bind ViewModel.UncUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <PasswordBox Header="{helpers:ResourceString Name=Setup_Target_PasswordOptional}" Password="{Binding UncPassword, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.FtpTargetVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Target_EnterFtpDetails}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpHost}" Text="{x:Bind ViewModel.FtpHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpPort}" Text="{x:Bind ViewModel.FtpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpUser}" Text="{x:Bind ViewModel.FtpUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <PasswordBox Header="{helpers:ResourceString Name=Setup_Target_FtpPassword}" Password="{Binding FtpPassword, Mode=TwoWay}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpFolder}" Text="{x:Bind ViewModel.FtpFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpEncoding}" Text="{x:Bind ViewModel.FtpEncoding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="{helpers:ResourceString Name=Setup_Target_EnforceUnencryptedFtp}" IsChecked="{x:Bind ViewModel.FtpEnforceUnencrypted, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Mode -->
                    <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.ModeVisibility, Mode=OneWay}">
                        <StackPanel Spacing="8">
                            <RadioButton Content="{helpers:ResourceString Name=Setup_Mode_Automatic}"
                                         IsChecked="{Binding SelectedTaskType, Mode=TwoWay, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource TaskType_Auto}}" />
                            <TextBlock Margin="28,0,0,0" Opacity="0.75" TextWrapping="WrapWholeWords"
                                       Text="{helpers:ResourceString Name=Setup_Mode_AutomaticDescription}" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <RadioButton Content="{helpers:ResourceString Name=Setup_Mode_Manual}"
                                         IsChecked="{Binding SelectedTaskType, Mode=TwoWay, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource TaskType_Manual}}" />
                            <TextBlock Margin="28,0,0,0" Opacity="0.75" TextWrapping="WrapWholeWords"
                                       Text="{helpers:ResourceString Name=Setup_Mode_ManualDescription}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Import media -->
                    <StackPanel Spacing="28" Visibility="{x:Bind ViewModel.ImportMediaVisibility, Mode=OneWay}">
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="12">
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Target_Local_Title}"
                                Description="{helpers:ResourceString Name=Setup_Import_Local_Description}"
                                Glyph="&#xEDA2;"
                                IsSelected="{Binding SelectedImportSourceKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Import_Local}}"
                                Command="{x:Bind ViewModel.SelectImportSourceCommand}"
                                CommandParameter="{converters:EnumValue Type=models:SetupImportSourceKind, Member=LocalMedia}" />
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Target_Ftp_Title}"
                                Description="{helpers:ResourceString Name=Setup_Target_Ftp_Description}"
                                Glyph="&#xE839;"
                                IsSelected="{Binding SelectedImportSourceKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Import_Ftp}}"
                                Command="{x:Bind ViewModel.SelectImportSourceCommand}"
                                CommandParameter="{converters:EnumValue Type=models:SetupImportSourceKind, Member=Ftp}" />
                            <controls:SetupOptionCard
                                Title="{helpers:ResourceString Name=Setup_Import_FolderPath_Title}"
                                Description="{helpers:ResourceString Name=Setup_Import_FolderPath_Description}"
                                Glyph="&#xE8B7;"
                                IsSelected="{Binding SelectedImportSourceKind, Converter={StaticResource EnumComparisonConverter}, ConverterParameter={StaticResource Import_Path}}"
                                Command="{x:Bind ViewModel.SelectImportSourceCommand}"
                                CommandParameter="{converters:EnumValue Type=models:SetupImportSourceKind, Member=ExplicitPath}" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.LocalImportVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Import_SelectDrive}" />
                            <ListView
                                Height="160"
                                ItemsSource="{x:Bind ViewModel.AvailableDrives, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedImportDrive, Mode=TwoWay}"
                                DisplayMemberPath="DisplayName" />
                            <Button Command="{x:Bind ViewModel.RefreshDrivesCommand}" Content="{helpers:ResourceString Name=Setup_Target_RefreshDrives}" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.ExplicitImportVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Import_ChooseFolder}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Import_FolderPath_Title}" Text="{x:Bind ViewModel.ExplicitImportPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Command="{x:Bind ViewModel.BrowseExplicitImportPathCommand}" Content="{helpers:ResourceString Name=MsgBox_Browse}" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.FtpImportVisibility, Mode=OneWay}">
                            <TextBlock FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Target_EnterFtpDetails}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpHost}" Text="{x:Bind ViewModel.ImportFtpHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpPort}" Text="{x:Bind ViewModel.ImportFtpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpUser}" Text="{x:Bind ViewModel.ImportFtpUser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <PasswordBox Header="{helpers:ResourceString Name=Setup_Target_FtpPassword}" Password="{Binding ImportFtpPassword, Mode=TwoWay}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpFolder}" Text="{x:Bind ViewModel.ImportFtpFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="{helpers:ResourceString Name=Setup_Target_FtpEncoding}" Text="{x:Bind ViewModel.ImportFtpEncoding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="{helpers:ResourceString Name=Setup_Target_EnforceUnencryptedFtp}" IsChecked="{x:Bind ViewModel.ImportFtpEnforceUnencrypted, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Import select -->
                    <ListView
                        Visibility="{x:Bind ViewModel.ImportSelectVisibility, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.DiscoveredBackups, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedDiscoveredBackup, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DiscoveredBackup">
                                <TextBlock Text="{x:Bind DisplayName, Mode=OneTime}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Import remap -->
                    <Grid Visibility="{x:Bind ViewModel.ImportRemapVisibility, Mode=OneWay}" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="12,0,12,0" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Import_OriginalPath}" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{helpers:ResourceString Name=Setup_Import_PathOnThisPc}" />
                        </Grid>

                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.SourceRemaps, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedSourceRemap, Mode=TwoWay}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="12,8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SourceRemap">
                                    <Grid ColumnSpacing="16" Padding="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind OriginalPath, Mode=OneTime}"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind CurrentPath, Mode=OneTime}"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button
                            Grid.Row="2"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.RemapSelectedSourceCommand}"
                            Content="{helpers:ResourceString Name=Setup_Import_ChangePath}" />
                    </Grid>

                    <!-- Progress -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="{x:Bind ViewModel.ProgressVisibility, Mode=OneWay}">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="48" Height="48" />
                        <TextBlock Text="{helpers:ResourceString Name=Setup_Progress_Applying}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border
                Grid.Row="2"
                Margin="0,28,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{x:Bind ViewModel.WizardChromeVisibility, Mode=OneWay}" />

            <Grid
                Grid.Row="3"
                Margin="0,20,0,0"
                ColumnSpacing="12"
                Visibility="{x:Bind ViewModel.WizardChromeVisibility, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="{x:Bind ViewModel.ValidationErrorMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <Button
                    Grid.Column="1"
                    MinWidth="100"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Content="{helpers:ResourceString Name=MsgBox_Back}"
                    Visibility="{x:Bind ViewModel.BackButtonVisibility, Mode=OneWay}" />
                <Button
                    Grid.Column="2"
                    MinWidth="100"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.GoNextCommand}"
                    Content="{helpers:ResourceString Name=MsgBox_Next}"
                    Visibility="{x:Bind ViewModel.NextButtonVisibility, Mode=OneWay}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
