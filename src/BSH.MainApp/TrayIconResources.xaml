<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:helpers="using:BSH.MainApp.Helpers"
    >
    <XamlUICommand
        x:Key="ShowBrowserWindowCommand"
        Label="{helpers:ResourceString Name=Tray_ShowBackupBrowser}"
        Description="{helpers:ResourceString Name=Tray_ShowBackupBrowser}"
        >
        <XamlUICommand.IconSource>
            <SymbolIconSource Symbol="BrowsePhotos" />
        </XamlUICommand.IconSource>
    </XamlUICommand>
    <XamlUICommand
        x:Key="ShowMainWindowCommand"
        Label="{helpers:ResourceString Name=Tray_StatusAndConfiguration}"
        Description="{helpers:ResourceString Name=Tray_StatusAndConfiguration}"
        >
        <XamlUICommand.IconSource>
            <SymbolIconSource Symbol="Setting" />
        </XamlUICommand.IconSource>
    </XamlUICommand>
    <XamlUICommand
        x:Key="StartManualBackupCommand"
        Label="{helpers:ResourceString Name=Tray_StartManualBackup}"
        Description="{helpers:ResourceString Name=Tray_StartManualBackup}"
        >
        <XamlUICommand.IconSource>
            <SymbolIconSource Symbol="Save" />
        </XamlUICommand.IconSource>
    </XamlUICommand>
    <XamlUICommand
        x:Key="StartManualBackupExtendedCommand"
        Label="{helpers:ResourceString Name=Tray_StartManualBackupWithSettings}"
        Description="{helpers:ResourceString Name=Tray_StartManualBackupWithSettings}"
        >
    </XamlUICommand>
    <XamlUICommand
        x:Key="ExitApplicationCommand"
        Label="{helpers:ResourceString Name=Tray_Exit}"
        Description="{helpers:ResourceString Name=Tray_Exit}"
        >
    </XamlUICommand>
    <tb:TaskbarIcon
        x:Key="TrayIcon"
        Visibility="Visible"
        ToolTipText="{helpers:ResourceString Name=AppDisplayName}"
        ContextMenuMode="SecondWindow"
        LeftClickCommand="{StaticResource ShowMainWindowCommand}"
        NoLeftClickDelay="True"
        IconSource="ms-appx:///Assets/app_ico.ico"
        >
        <tb:TaskbarIcon.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Command="{StaticResource ShowMainWindowCommand}" />
                <MenuFlyoutItem Command="{StaticResource ShowBrowserWindowCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Command="{StaticResource StartManualBackupCommand}" />
                <MenuFlyoutItem Command="{StaticResource StartManualBackupExtendedCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Command="{StaticResource ExitApplicationCommand}" />
            </MenuFlyout>
        </tb:TaskbarIcon.ContextFlyout>
    </tb:TaskbarIcon>
</ResourceDictionary>
